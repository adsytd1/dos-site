          <a href="case-amadey.html" style="display:inline-flex;align-items:center;gap:8px;margin-top:12px;padding:10px 20px;background:var(--accent-dim);border:1px solid rgba(0,230,118,.2);border-radius:100px;font-family:var(--mono);font-size:13px;font-weight:600;color:var(--accent);transition:all var(--transition)">Смотреть кейс &#8594;</a>
