<link rel="dns-prefetch" href="https://www.clarity.ms">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0a;--surface:#111;--card:#161616;--card-hover:#1c1c1c;--border:#1e1e1e;--border-light:#2a2a2a;--accent:#00e676;--accent-dim:rgba(0,230,118,.08);--accent-mid:rgba(0,230,118,.15);--accent-glow:rgba(0,230,118,.25);--accent2:#69f0ae;--blue:#38bdf8;--purple:#a78bfa;--gold:#fbbf24;--orange:#fb923c;--text:#f0f0f0;--text-secondary:#999;--text-muted:#888;--mono:'JetBrains Mono',monospace;--sans:'Outfit',-apple-system,sans-serif;--radius:16px;--radius-sm:10px;--radius-xs:6px;--max-w:1100px;--transition:.3s cubic-bezier(.4,0,.2,1)}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.65;overflow-x:hidden;-webkit-font-smoothing:antialiased}
::selection{background:var(--accent-mid);color:var(--accent)}
a{color:inherit;text-decoration:none}
button{font-family:inherit}
.container{max-width:var(--max-w);margin:0 auto;padding:0 32px}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.02) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0}

/* NAVBAR */
.navbar{position:fixed;top:0;left:0;right:0;z-index:100;padding:16px 32px;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);background:rgba(10,10,10,.8);border-bottom:1px solid var(--border);transition:var(--transition)}
.navbar-logo{font-family:var(--mono);font-weight:600;font-size:20px;color:var(--accent);letter-spacing:2px}
.navbar-links{display:flex;gap:32px;list-style:none}
.navbar-links a{font-size:14px;font-weight:500;color:var(--text-secondary);transition:color var(--transition)}
.navbar-links a:hover{color:var(--accent)}
.navbar-cta{padding:10px 24px;background:var(--accent);color:#000;font-weight:600;font-size:13px;border-radius:100px;transition:all var(--transition);letter-spacing:.5px}
.navbar-cta:hover{box-shadow:0 0 30px var(--accent-glow);transform:translateY(-1px)}
.mobile-toggle{display:none;background:none;border:none;color:var(--text);cursor:pointer;width:28px;height:20px;position:relative;flex-shrink:0}
.mobile-toggle span{display:block;position:absolute;height:2px;width:100%;background:var(--text);border-radius:2px;left:0;transition:all .25s ease}
.mobile-toggle span:nth-child(1){top:0}
.mobile-toggle span:nth-child(2){top:9px}
.mobile-toggle span:nth-child(3){top:18px}
.navbar.nav-open .mobile-toggle span:nth-child(1){top:9px;transform:rotate(45deg)}
.navbar.nav-open .mobile-toggle span:nth-child(2){opacity:0}
.navbar.nav-open .mobile-toggle span:nth-child(3){top:9px;transform:rotate(-45deg)}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:120px 32px 80px;overflow:hidden}
.hero::before{content:'';position:absolute;top:-300px;left:50%;transform:translateX(-50%);width:900px;height:900px;background:radial-gradient(circle,var(--accent-dim) 0%,transparent 65%);pointer-events:none}
.hero-badge{display:inline-flex;align-items:center;gap:10px;padding:8px 22px;background:var(--accent-dim);border:1px solid rgba(0,230,118,.15);border-radius:100px;font-family:var(--mono);font-size:13px;font-weight:500;color:var(--accent);margin-bottom:40px;animation:fadeInDown .8s ease both}
.hero-badge::before{content:'';width:8px;height:8px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite}
.hero h1{font-size:clamp(40px,7vw,80px);font-weight:900;line-height:1.05;letter-spacing:-2px;margin-bottom:28px;animation:fadeInUp .8s ease .15s both}
.hero h1 .accent-text{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
/* HERO ROTATE */
.hero-rotate-wrap{margin-bottom:48px;animation:fadeInUp .8s ease .3s both}
.hero-rotate-text{font-size:clamp(18px,3vw,26px);color:var(--text-secondary);font-weight:400;line-height:1.6;max-width:600px;display:flex;flex-wrap:wrap;justify-content:center;align-items:baseline;gap:0 8px}
.hero-rotate{display:inline-flex;position:relative;overflow:hidden;vertical-align:baseline;min-width:220px;height:1.3em;justify-content:center}
.hero-rotate-word{display:block;position:absolute;top:0;left:50%;transform:translateX(-50%) translateY(100%);opacity:0;transition:all .5s cubic-bezier(.4,0,.2,1);color:var(--accent);font-weight:700;white-space:nowrap}
.hero-rotate-word.active{opacity:1;transform:translateX(-50%) translateY(0)}
.hero-rotate-word.exit{opacity:0;transform:translateX(-50%) translateY(-100%)}
.hero-channels{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:20px}
.hero-channel{padding:6px 16px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-family:var(--mono);font-size:12px;color:var(--text-muted);font-weight:500;transition:all .3s ease}
.hero-channel:hover{border-color:var(--accent);color:var(--accent)}
.hero-cta-group{display:flex;align-items:center;gap:16px;flex-wrap:wrap;justify-content:center;animation:fadeInUp .8s ease .45s both}
.btn-primary{display:inline-flex;align-items:center;gap:10px;padding:18px 36px;background:var(--accent);color:#000;font-family:var(--sans);font-weight:700;font-size:16px;border:none;border-radius:100px;cursor:pointer;transition:all var(--transition);box-shadow:0 0 40px var(--accent-dim);letter-spacing:.3px}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 0 60px var(--accent-glow)}
.btn-ghost{display:inline-flex;align-items:center;gap:8px;padding:16px 28px;background:transparent;color:var(--text-secondary);font-family:var(--sans);font-weight:600;font-size:15px;border:1px solid var(--border-light);border-radius:100px;cursor:pointer;transition:all var(--transition)}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
.btn-book{display:inline-flex;align-items:center;gap:8px;padding:16px 28px;background:rgba(56,189,248,.08);color:var(--blue);font-family:var(--sans);font-weight:600;font-size:15px;border:1px solid rgba(56,189,248,.2);border-radius:100px;cursor:pointer;transition:all var(--transition)}
.btn-book:hover{background:rgba(56,189,248,.15);border-color:var(--blue);transform:translateY(-2px);box-shadow:0 8px 30px rgba(56,189,248,.15)}
.hero-stats{display:flex;gap:48px;margin-top:56px;animation:fadeInUp .8s ease .6s both}
.hero-stat{text-align:center}
.hero-stat-num{font-family:var(--mono);font-size:32px;font-weight:700;color:var(--accent);line-height:1}
.hero-stat-label{font-size:13px;color:var(--text-muted);margin-top:6px}

/* TRUST BAR */
.trust-bar{margin-top:48px;text-align:center;animation:fadeInUp .8s ease .75s both}
.trust-bar-label{font-size:12px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--text-muted);margin-bottom:20px}
.trust-logos{display:flex;align-items:center;justify-content:center;gap:36px;flex-wrap:wrap}
.trust-logo{display:flex;align-items:center;gap:8px;padding:8px 18px;background:var(--card);border:1px solid var(--border);border-radius:10px;font-size:13px;font-weight:600;color:var(--text-secondary);transition:all .3s ease;white-space:nowrap}
.trust-logo:hover{border-color:var(--accent);color:var(--text);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.3)}
.trust-logo svg{width:20px;height:20px;flex-shrink:0}
.trust-logo picture,.trust-logo img{flex-shrink:0;display:flex}
@media(max-width:768px){.trust-logos{gap:12px}.trust-logo{font-size:12px;padding:6px 14px}}

/* SECTIONS */
.section{position:relative;padding:120px 0;z-index:1}
.section-label{font-family:var(--mono);font-size:13px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:16px}
.section-title{font-size:clamp(28px,5vw,48px);font-weight:800;line-height:1.15;letter-spacing:-1px;margin-bottom:20px}
.section-desc{font-size:17px;color:var(--text-secondary);max-width:560px;line-height:1.7}
.section-header{margin-bottom:64px}
.section-header--center{text-align:center}
.section-header--center .section-desc{margin:0 auto}
.divider{height:1px;background:linear-gradient(90deg,transparent,var(--border-light),transparent)}

/* SERVICES */
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.service-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:36px 28px;transition:all var(--transition);position:relative;overflow:hidden}
.service-card::before{content:'';position:absolute;top:0;left:0;width:4px;height:0;border-radius:0 4px 4px 0;transition:height .4s ease}
.service-card:hover::before{height:100%}
.service-card:nth-child(1)::before{background:var(--accent)}
.service-card:nth-child(2)::before{background:var(--blue)}
.service-card:nth-child(3)::before{background:var(--purple)}
.service-card:hover{border-color:var(--border-light);transform:translateY(-4px);box-shadow:0 20px 60px rgba(0,0,0,.3)}
.service-icon{font-size:36px;margin-bottom:20px;display:block}
.service-card h3{font-size:20px;font-weight:700;margin-bottom:12px}
.service-card p{font-size:14px;color:var(--text-secondary);line-height:1.7}
.service-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}
.service-tag{padding:4px 12px;background:var(--accent-dim);border-radius:100px;font-family:var(--mono);font-size:11px;color:var(--accent);font-weight:500}
.service-tag--blue{background:rgba(56,189,248,.08);color:var(--blue)}
.service-tag--purple{background:rgba(167,139,250,.08);color:var(--purple)}

/* COMPARE TABLE */
.compare-section{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:48px 40px;margin-top:64px}
.compare-section h3{font-size:24px;font-weight:800;margin-bottom:8px;text-align:center}
.compare-subtitle{font-size:15px;color:var(--text-muted);text-align:center;margin-bottom:36px}
.compare-table{width:100%;border-collapse:collapse}
.compare-table th{font-family:var(--mono);font-size:13px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:14px 16px;text-align:left;border-bottom:2px solid var(--border-light)}
.compare-table th:first-child{color:var(--text-muted);width:40%}
.compare-table th:nth-child(2){color:var(--text-muted)}
.compare-table th:nth-child(3){color:var(--accent)}
.compare-table td{padding:14px 16px;font-size:14px;border-bottom:1px solid var(--border);color:var(--text-secondary)}
.compare-table td:nth-child(3){color:var(--accent);font-weight:600}
.compare-table tr:last-child td{border-bottom:none}
.compare-table .val-bad{color:#ff5252}
.compare-table .val-good{color:var(--accent)}
.compare-bottom{text-align:center;margin-top:32px;font-size:15px;color:var(--text-secondary)}
.compare-bottom strong{color:var(--accent)}

/* VIDEO DEMO */
.video-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.video-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:all var(--transition)}
.video-card:hover{border-color:var(--border-light);transform:translateY(-3px);box-shadow:0 16px 50px rgba(0,0,0,.25)}
.video-placeholder{position:relative;width:100%;padding-top:56.25%;background:var(--surface);cursor:pointer}
.video-placeholder .play-btn{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:64px;height:64px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;transition:all var(--transition);box-shadow:0 0 40px var(--accent-dim)}
.video-placeholder .play-btn::after{content:'';width:0;height:0;border-style:solid;border-width:10px 0 10px 18px;border-color:transparent transparent transparent #000;margin-left:3px}
.video-card:hover .play-btn{transform:translate(-50%,-50%) scale(1.1);box-shadow:0 0 60px var(--accent-glow)}
.video-placeholder .coming{position:absolute;bottom:12px;right:12px;padding:4px 12px;background:rgba(0,0,0,.7);border-radius:100px;font-family:var(--mono);font-size:11px;color:var(--text-muted)}
.video-card-info{padding:16px 20px}
.video-card-info h3{font-size:15px;font-weight:600;margin-bottom:4px}
.video-card-info p{font-size:13px;color:var(--text-muted)}

/* PROJECTS */
.projects-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.project-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:36px 32px;transition:all var(--transition);position:relative;overflow:hidden}
.project-card:hover{border-color:var(--border-light);transform:translateY(-2px);box-shadow:0 16px 50px rgba(0,0,0,.25)}
.project-card--featured{grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr;gap:40px;padding:48px 40px;border-color:var(--accent)}
.project-card--featured::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2))}
.project-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.project-industry{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:1px;text-transform:uppercase;padding:4px 12px;border-radius:100px}
.project-industry--finance{background:rgba(251,191,36,.08);color:var(--gold)}
.project-industry--realestate{background:rgba(251,146,60,.08);color:var(--orange)}
.project-industry--music{background:rgba(167,139,250,.08);color:var(--purple)}
.project-industry--law{background:rgba(167,139,250,.08);color:var(--purple)}
.project-industry--dental{background:rgba(56,189,248,.08);color:var(--blue)}
.project-industry--edu{background:rgba(0,230,118,.08);color:var(--accent)}
.project-industry--hr{background:rgba(251,191,36,.08);color:var(--gold)}
.project-industry--coaching{background:rgba(251,146,60,.08);color:var(--orange)}
.project-industry--marketing{background:rgba(56,189,248,.08);color:var(--blue)}
.project-name{font-size:22px;font-weight:700;margin-bottom:10px;display:flex;align-items:center;gap:10px}
.project-logo{border-radius:6px;object-fit:contain;flex-shrink:0}
.project-name picture{display:flex;flex-shrink:0}
.project-ig{display:inline-flex;align-items:center;gap:6px;margin-top:8px;padding:6px 14px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.12);border-radius:100px;font-family:var(--mono);font-size:11px;font-weight:500;color:#a78bfa;transition:all .3s ease;text-decoration:none}
.project-ig:hover{background:rgba(167,139,250,.15);border-color:#a78bfa;color:#c4b5fd;transform:translateY(-1px)}
.project-ig svg{width:14px;height:14px;flex-shrink:0}
.project-meta{font-size:12px;color:var(--text-muted);margin-top:6px;font-family:var(--mono)}
.project-desc{font-size:14px;color:var(--text-secondary);line-height:1.7;margin-bottom:20px}
.project-features{list-style:none;display:flex;flex-direction:column;gap:8px}
.project-features li{font-size:13px;color:var(--text-secondary);display:flex;align-items:center;gap:10px}
.project-features li::before{content:'\2713';color:var(--accent);font-weight:700;font-size:14px;min-width:16px}
.project-result{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;background:var(--accent-dim);border-radius:var(--radius-xs);font-family:var(--mono);font-size:13px;font-weight:600;color:var(--accent);margin-top:16px}
.project-result--big{display:block;padding:16px 20px;font-size:14px;margin-top:20px;border:1px solid rgba(0,230,118,.2);border-radius:var(--radius-sm)}
.project-result--big .big-num{font-size:28px;font-weight:800;display:block;margin-bottom:4px}

/* PHONE MOCKUP */
.phone-mockup{width:100%;max-width:320px;margin:0 auto;background:var(--surface);border-radius:24px;border:2px solid var(--border-light);overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.5)}
.phone-header{padding:16px 20px;background:var(--card);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px}
.phone-avatar{width:36px;height:36px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:700;color:#000;font-size:14px}
.phone-name{font-weight:600;font-size:14px}
.phone-status{font-size:11px;color:var(--accent)}
.phone-chat{padding:20px 16px;display:flex;flex-direction:column;gap:10px;min-height:300px}
.chat-msg{max-width:85%;padding:10px 14px;border-radius:14px;font-size:13px;line-height:1.5}
.chat-msg--bot{background:var(--card);border:1px solid var(--border);align-self:flex-start;border-bottom-left-radius:4px}
.chat-msg--user{background:var(--accent);color:#000;font-weight:500;align-self:flex-end;border-bottom-right-radius:4px}

/* FLOW */
.flow-steps{position:relative;display:flex;flex-direction:column}
.flow-steps::before{content:'';position:absolute;left:32px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--accent),var(--blue),var(--purple),transparent)}
.flow-step{display:flex;gap:32px;padding:32px 0;position:relative}
.flow-num{width:64px;height:64px;min-width:64px;background:var(--bg);border:2px solid var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:22px;color:var(--accent);z-index:2}
.flow-step:nth-child(2) .flow-num{border-color:var(--blue);color:var(--blue)}
.flow-step:nth-child(3) .flow-num{border-color:var(--blue);color:var(--blue)}
.flow-step:nth-child(4) .flow-num{border-color:var(--purple);color:var(--purple)}
.flow-step:nth-child(5) .flow-num{border-color:var(--purple);color:var(--purple)}
.flow-content{padding-top:8px}
.flow-content h3{font-size:20px;font-weight:700;margin-bottom:8px}
.flow-content p{font-size:15px;color:var(--text-secondary);max-width:500px;line-height:1.7}
.flow-detail{font-family:var(--mono);font-size:12px;color:var(--text-muted);margin-top:12px;padding:8px 14px;background:var(--surface);border-radius:var(--radius-xs);display:inline-block}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:auto 1fr;gap:48px;align-items:center}
.about-avatar{width:140px;height:140px;border-radius:50%;border:3px solid var(--accent);flex-shrink:0;overflow:hidden;box-shadow:0 0 40px var(--accent-dim)}
.about-avatar img{width:100%;height:100%;object-fit:cover}
.about-text p{color:var(--text-secondary);font-size:15px;line-height:1.8;margin-bottom:16px}
.about-timeline{margin:24px 0;display:flex;flex-direction:column;gap:12px}
.about-tl-item{display:flex;align-items:center;gap:12px;font-size:14px;color:var(--text-secondary)}
.about-tl-year{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--accent);min-width:48px}
.about-facts{display:flex;gap:16px;margin-top:32px;flex-wrap:wrap}
.about-fact{padding:10px 20px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-family:var(--mono);font-size:13px;font-weight:500;color:var(--text-secondary)}
.about-fact span{color:var(--accent);font-weight:700}

/* RESULTS */
.results-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:48px}
.result-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:32px 24px;text-align:center;transition:all var(--transition)}
.result-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.result-num{font-family:var(--mono);font-size:40px;font-weight:800;color:var(--accent);line-height:1;margin-bottom:8px}
.result-label{font-size:14px;color:var(--text-secondary)}
.benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.benefit-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:32px 28px;transition:all var(--transition)}
.benefit-card:hover{border-color:var(--border-light)}
.benefit-icon{font-size:28px;margin-bottom:16px}
.benefit-card h3{font-size:16px;font-weight:700;margin-bottom:10px}
.benefit-card p{font-size:14px;color:var(--text-secondary);line-height:1.7}
.benefit-detail{max-height:0;overflow:hidden;transition:max-height .4s ease,margin .3s ease;margin-top:0}
.benefit-card.open .benefit-detail{max-height:300px;margin-top:14px}
.benefit-detail-inner{padding:14px 16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;color:var(--text-secondary);line-height:1.7}
.benefit-detail-inner strong{color:var(--accent);font-weight:600}
.benefit-more{display:inline-flex;align-items:center;gap:4px;margin-top:12px;padding:0;background:none;border:none;color:var(--text-muted);font-size:12px;font-family:var(--mono);cursor:pointer;transition:color .2s}
.benefit-more:hover{color:var(--accent)}
.benefit-more svg{width:12px;height:12px;transition:transform .3s}
.benefit-card.open .benefit-more svg{transform:rotate(180deg)}

/* PRICING */
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;align-items:stretch}
.pricing-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:36px 28px;display:flex;flex-direction:column;transition:all var(--transition);position:relative}
.pricing-card:hover{border-color:var(--accent);transform:translateY(-6px);box-shadow:0 20px 60px rgba(0,0,0,.3),0 0 30px rgba(0,230,118,.1)}
.pricing-card--popular{border-color:var(--accent);transform:scale(1.03);z-index:2}
.pricing-card--popular::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:var(--radius) var(--radius) 0 0}
.pricing-card--popular:hover{transform:scale(1.05)}
.pricing-popular-badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);padding:6px 20px;background:var(--accent);color:#000;font-family:var(--mono);font-size:11px;font-weight:700;border-radius:100px;letter-spacing:1px;text-transform:uppercase}
.pricing-name{font-family:var(--mono);font-size:13px;font-weight:500;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px}
.pricing-title{font-size:28px;font-weight:800;margin-bottom:16px}
.pricing-desc{font-size:14px;color:var(--text-muted);font-style:italic;margin-bottom:24px;line-height:1.6}
.pricing-features{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:32px;flex-grow:1}
.pricing-features li{font-size:13px;color:var(--text-secondary);display:flex;align-items:flex-start;gap:10px;line-height:1.5}
.pricing-features li::before{content:'\2713';color:var(--accent);font-weight:700;min-width:14px;margin-top:1px}
.pricing-time{font-family:var(--mono);font-size:12px;color:var(--text-muted);margin-bottom:20px}
.pricing-btn{display:block;text-align:center;padding:16px;background:transparent;border:1px solid var(--border-light);border-radius:100px;font-weight:600;font-size:15px;color:var(--text-secondary);transition:all var(--transition);cursor:pointer}
.pricing-btn:hover{border-color:var(--accent);color:var(--accent)}
.pricing-card--popular .pricing-btn{background:var(--accent);color:#000;border-color:var(--accent)}
.pricing-card--popular .pricing-btn:hover{box-shadow:0 0 40px var(--accent-glow)}
.pricing-note{text-align:center;margin-top:32px;font-size:14px;color:var(--text-muted)}
.guarantee-badges{display:flex;justify-content:center;gap:20px;flex-wrap:wrap;margin-top:32px}
.guarantee-badge{display:flex;align-items:center;gap:10px;padding:12px 20px;background:rgba(0,230,118,.04);border:1px solid rgba(0,230,118,.12);border-radius:100px;font-size:13px;font-weight:500;color:var(--text-secondary);transition:all .3s ease}
.guarantee-badge:hover{border-color:var(--accent);color:var(--text);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
.guarantee-badge svg{flex-shrink:0}
@media(max-width:768px){.guarantee-badges{flex-direction:column;align-items:center}.guarantee-badge{width:100%;justify-content:center}}

/* REVIEWS CAROUSEL — 2x2 grid pages */
.reviews-carousel{position:relative;overflow:hidden;width:100%}
.reviews-track{display:flex;transition:transform .5s cubic-bezier(.4,0,.2,1);width:100%}
.review-page{width:100%;min-width:100%;max-width:100%;flex:0 0 100%;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:260px 260px;gap:12px;box-sizing:border-box}
.review-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;min-height:0;min-width:0}
.review-card:hover{border-color:var(--border-light)}
.review-card.empty-card{background:transparent;border:1px dashed var(--border)}
.review-media{flex:1;min-height:0;display:flex;align-items:center;justify-content:center;background:#0d0d0d;overflow:hidden;position:relative}
.review-media img{width:100%;height:100%;object-fit:contain;display:block}
.review-media video{width:100%;height:100%;object-fit:contain;display:block;background:#000}
.review-caption{padding:8px 14px;border-top:1px solid var(--border);flex-shrink:0}
.review-caption .rc-name{font-weight:600;font-size:12px}
.review-caption .rc-role{font-size:11px;color:var(--text-muted)}
.carousel-controls{display:flex;justify-content:center;gap:12px;margin-top:32px}
.carousel-btn{width:48px;height:48px;border-radius:50%;background:var(--card);border:1px solid var(--border);color:var(--text-secondary);font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all var(--transition)}
.carousel-btn:hover{border-color:var(--accent);color:var(--accent)}
.carousel-dots{display:flex;align-items:center;gap:8px;margin:0 16px}
.carousel-dot{width:8px;height:8px;border-radius:50%;background:var(--border-light);transition:all var(--transition);cursor:pointer}
.carousel-dot.active{background:var(--accent);width:24px;border-radius:4px}

/* STACK */
.stack-grid{display:flex;flex-wrap:wrap;gap:12px;justify-content:center}
.stack-item{padding:12px 24px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-family:var(--mono);font-size:14px;font-weight:500;color:var(--text-secondary);transition:all var(--transition)}
.stack-item:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-dim)}

/* LEAD MAGNETS */
.magnets-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.magnet-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:36px 28px;display:flex;flex-direction:column;transition:all var(--transition)}
.magnet-card:hover{border-color:var(--border-light);transform:translateY(-3px)}
.magnet-icon{font-size:40px;margin-bottom:16px}
.magnet-format{font-family:var(--mono);font-size:11px;color:var(--text-muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:12px}
.magnet-card h3{font-size:17px;font-weight:700;margin-bottom:12px;line-height:1.4}
.magnet-card p{font-size:14px;color:var(--text-secondary);line-height:1.7;flex-grow:1;margin-bottom:24px}
.magnet-btn{display:block;text-align:center;padding:14px;background:var(--accent-dim);border:1px solid rgba(0,230,118,.15);border-radius:100px;font-weight:600;font-size:14px;color:var(--accent);transition:all var(--transition)}
.magnet-btn:hover{background:var(--accent);color:#000}

/* CTA + FORM */
.cta-section{text-align:center;position:relative}
.cta-section::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:700px;background:radial-gradient(circle,var(--accent-dim) 0%,transparent 60%);pointer-events:none}
.cta-box{background:var(--card);border:2px solid var(--accent);border-radius:24px;padding:64px 48px;position:relative;overflow:hidden;max-width:800px;margin:0 auto}
.cta-box::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--accent),var(--accent2),var(--blue))}
.cta-box h2{font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px;letter-spacing:-1px}
.cta-box>p{color:var(--text-secondary);font-size:17px;margin-bottom:40px;max-width:480px;margin-left:auto;margin-right:auto}
.cta-buttons{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:48px}
.cta-links{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-top:32px}
.cta-link{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;background:var(--surface);border:1px solid var(--border-light);border-radius:100px;font-size:14px;font-weight:500;color:var(--text-secondary);transition:all var(--transition)}
.cta-link:hover{border-color:var(--accent);color:var(--accent)}
.form-section{margin-top:48px;text-align:left}
.form-section h3{font-size:20px;font-weight:700;margin-bottom:24px;text-align:center}
.contact-form{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:600px;margin:0 auto}
.form-group{display:flex;flex-direction:column;gap:6px}
.form-group--full{grid-column:1/-1}
.form-group label{font-size:13px;font-weight:500;color:var(--text-muted)}
.form-group input,.form-group textarea{padding:14px 18px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:var(--sans);font-size:15px;outline:none;transition:border-color var(--transition);resize:vertical}
.form-group input:focus,.form-group textarea:focus{border-color:var(--accent)}
.form-group textarea{min-height:100px}
.form-submit{grid-column:1/-1;padding:18px;background:var(--accent);color:#000;font-family:var(--sans);font-weight:700;font-size:16px;border:none;border-radius:100px;cursor:pointer;transition:all var(--transition)}
.form-submit:hover{box-shadow:0 0 40px var(--accent-glow);transform:translateY(-2px)}

/* FOOTER */
footer{padding:40px 0;border-top:1px solid var(--border);text-align:center;position:relative;z-index:1}
footer p{font-size:13px;color:var(--text-muted)}

/* FLOATING WA */
.floating-wa{position:fixed;bottom:24px;right:24px;width:60px;height:60px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px var(--accent-glow);z-index:999;opacity:0;transform:scale(.8) translateY(20px);transition:all .4s ease;pointer-events:none}
.floating-wa.visible{opacity:1;transform:scale(1) translateY(0);pointer-events:auto;animation:waPulse 2.5s infinite}
.floating-wa:hover{transform:scale(1.1);box-shadow:0 6px 30px var(--accent-glow);animation:none}
.floating-wa svg{width:28px;height:28px;fill:#000}

/* HERO SPLIT ROW */
.hero-cta-row{display:flex;align-items:center;gap:16px;flex-wrap:wrap;justify-content:center;animation:fadeInUp .8s ease .45s both;margin-bottom:16px}
.hero-split{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;width:100%;max-width:var(--max-w);margin:40px auto 0;animation:fadeInUp .8s ease .6s both}

/* HERO MINI BOT */
.hero-bot{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px;width:100%;text-align:left}
.hero-bot-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.hero-bot-avatar{width:32px;height:32px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:700;color:#000;font-size:12px;flex-shrink:0}
.hero-bot-name{font-size:13px;font-weight:600}
.hero-bot-status{font-size:10px;color:var(--accent)}
.hero-bot-msgs{display:flex;flex-direction:column;gap:8px}
.hero-bot-msg{padding:10px 14px;border-radius:12px;font-size:13px;line-height:1.5;max-width:85%}
.hero-bot-msg--bot{background:var(--surface);border:1px solid var(--border);align-self:flex-start;border-bottom-left-radius:4px}
.hero-bot-msg--user{background:var(--accent);color:#000;font-weight:500;align-self:flex-end;border-bottom-right-radius:4px}
.hero-bot-msg:nth-child(2){animation-delay:.3s}
.hero-bot-msg:nth-child(3){animation-delay:.6s}
.hero-bot-typing{display:flex;gap:4px;padding:8px 12px;align-self:flex-start}
.hero-bot-typing span{width:6px;height:6px;background:var(--text-muted);border-radius:50%;animation:typing 1.2s infinite}
.hero-bot-typing span:nth-child(2){animation-delay:.2s}
.hero-bot-typing span:nth-child(3){animation-delay:.4s}
@keyframes typing{0%,60%,100%{opacity:.3;transform:translateY(0)}30%{opacity:1;transform:translateY(-4px)}}
.hero-bot-msgs{max-height:380px;overflow-y:auto;scrollbar-width:none;-ms-overflow-style:none}
.hero-bot-msgs::-webkit-scrollbar{display:none}
.hero-bot-msg{opacity:0;transform:translateY(12px);animation:msgIn .4s ease forwards}
@keyframes msgIn{to{opacity:1;transform:translateY(0)}}
.hero-bot-time{font-size:10px;color:var(--text-muted);text-align:center;margin:8px 0 4px;font-family:var(--mono)}
.hero-bot-voice{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:12px;background:var(--accent);color:#000;font-weight:500;align-self:flex-end;border-bottom-right-radius:4px;cursor:pointer;max-width:90%;opacity:0;transform:translateY(12px);animation:msgIn .4s ease forwards}
.hero-bot-voice svg{width:18px;height:18px;flex-shrink:0;fill:#000}
.hero-bot-voice-bar{display:flex;align-items:center;gap:2px;flex:1;height:20px}
.hero-bot-voice-bar span{width:3px;border-radius:2px;background:#000;opacity:.6}
.hero-bot-voice-dur{font-size:10px;font-family:var(--mono);opacity:.7}
.hero-bot-voice.playing{box-shadow:0 0 12px var(--accent-glow)}
.hero-bot-voice.playing .hero-bot-voice-bar span{animation:voiceBar .6s ease-in-out infinite alternate}
@keyframes voiceBar{from{opacity:.4}to{opacity:1}}
.hero-bot-msg b{font-weight:600}

/* HERO CTA CENTER */
.hero-cta-center{display:none}

/* HERO PAIN (compact, right) */
.hero-pain{width:100%;max-width:100%;padding:28px;background:linear-gradient(135deg,rgba(255,82,82,.06),rgba(255,82,82,.02));border:1px solid rgba(255,82,82,.12);border-radius:var(--radius);text-align:center}
.pain-counter{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:12px}
.pain-counter-num{font-family:var(--mono);font-size:36px;font-weight:800;color:#ff5252;line-height:1;text-shadow:0 0 30px rgba(255,82,82,.4);transition:transform .3s ease}
.pain-counter-num.bump{transform:scale(1.2)}
.pain-counter-label{font-size:12px;color:var(--text-muted);text-align:left;line-height:1.3;max-width:160px}
.pain-reasons{display:flex;flex-wrap:wrap;gap:6px;justify-content:center}
.pain-reason{padding:4px 10px;background:rgba(255,82,82,.06);border:1px solid rgba(255,82,82,.1);border-radius:100px;font-size:11px;color:#ff8a80;font-family:var(--mono);font-weight:500}
.pain-live{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:10px;font-size:10px;font-family:var(--mono);color:var(--text-muted);letter-spacing:1px;text-transform:uppercase}
.pain-dot{width:6px;height:6px;background:#ff5252;border-radius:50%;animation:pulse 2s infinite;box-shadow:0 0 8px rgba(255,82,82,.5);flex-shrink:0}
.hero-calc-link{display:inline-flex;align-items:center;gap:8px;margin-top:12px;padding:8px 20px;background:var(--accent-dim);border:1px solid rgba(0,230,118,.15);border-radius:100px;font-family:var(--mono);font-size:12px;font-weight:600;color:var(--accent);transition:all var(--transition);animation:fadeInUp .8s ease .35s both}
.hero-calc-link:hover{background:var(--accent);color:#000}

/* SYNERGY */
.synergy-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px;margin-bottom:40px}
.synergy-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:32px 24px;text-align:center;transition:all var(--transition)}
.synergy-card:hover{border-color:var(--border-light);transform:translateY(-2px)}
.synergy-card.synergy-best{border-color:var(--accent);background:linear-gradient(135deg,rgba(0,230,118,.04),rgba(0,230,118,.01))}
.synergy-icon{font-size:40px;margin-bottom:12px;display:block}
.synergy-title{font-size:18px;font-weight:700;margin-bottom:8px}
.synergy-pct{font-family:var(--mono);font-size:36px;font-weight:800;margin-bottom:4px}
.synergy-card:nth-child(1) .synergy-pct{color:var(--text-secondary)}
.synergy-card:nth-child(2) .synergy-pct{color:var(--accent)}
.synergy-card:nth-child(3) .synergy-pct{color:var(--gold)}
.synergy-desc{font-size:13px;color:var(--text-muted);line-height:1.6}
.synergy-note{text-align:center;font-size:16px;color:var(--text-secondary);line-height:1.7;max-width:700px;margin:0 auto 32px}
.synergy-note strong{color:var(--accent)}
.compare-cta{text-align:center;margin-top:40px}
.compare-cta .btn-primary{display:inline-flex}

/* CALCULATOR */
.calc-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:48px 40px;max-width:900px;margin:0 auto}
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.calc-inputs{display:flex;flex-direction:column;gap:24px}
.calc-field label{display:block;font-size:13px;font-weight:500;color:var(--text-muted);margin-bottom:8px}
.calc-field input[type=range]{width:100%;-webkit-appearance:none;appearance:none;height:6px;background:var(--border-light);border-radius:3px;outline:none;margin-top:8px}
.calc-field input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:pointer;box-shadow:0 0 10px var(--accent-glow)}
.calc-field input[type=range]::-moz-range-thumb{width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:pointer;border:none;box-shadow:0 0 10px var(--accent-glow)}
.calc-field input[type=range]::-moz-range-track{height:6px;background:var(--border-light);border-radius:3px}
.calc-field .calc-val{display:inline-block;font-family:var(--mono);font-size:20px;font-weight:700;color:var(--accent)}
.calc-results{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:32px 28px}
.calc-result-row{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--border)}
.calc-result-row:last-child{border-bottom:none}
.calc-result-label{font-size:14px;color:var(--text-secondary)}
.calc-result-val{font-family:var(--mono);font-size:18px;font-weight:700}
.calc-result-val.old{color:var(--text-muted)}
.calc-result-val.new{color:var(--accent)}
.calc-result-val.diff{color:var(--gold);font-size:22px}
.calc-result-highlight{text-align:center;padding:20px;margin-top:16px;background:var(--accent-dim);border:1px solid rgba(0,230,118,.2);border-radius:var(--radius-sm)}
.calc-result-highlight .big{font-family:var(--mono);font-size:32px;font-weight:800;color:var(--accent)}
.calc-result-highlight .sub{font-size:13px;color:var(--text-muted);margin-top:4px}
.calc-cta{text-align:center;margin-top:32px}

/* QUIZ FORM */
.quiz-wrap{max-width:600px;margin:0 auto}
.quiz-progress{display:flex;gap:6px;margin-bottom:32px}
.quiz-progress-bar{flex:1;height:4px;background:var(--border);border-radius:2px;transition:background .3s}
.quiz-progress-bar.active{background:var(--accent)}
.quiz-step{display:none}
.quiz-step.active{display:block}
.quiz-step h4{font-size:18px;font-weight:700;margin-bottom:20px}
.quiz-step p{font-size:14px;color:var(--text-muted);margin-bottom:20px}
.quiz-options{display:flex;flex-direction:column;gap:10px}
.quiz-option{display:flex;align-items:center;gap:12px;padding:14px 18px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:all var(--transition);font-size:14px;color:var(--text-secondary)}
.quiz-option:hover{border-color:var(--accent);color:var(--text)}
.quiz-option.selected{border-color:var(--accent);background:var(--accent-dim);color:var(--accent)}
.quiz-option input{display:none}
.quiz-option .qmark{width:20px;height:20px;border-radius:50%;border:2px solid var(--border-light);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all var(--transition)}
.quiz-option.selected .qmark{border-color:var(--accent);background:var(--accent)}
.quiz-option.selected .qmark::after{content:'';width:6px;height:6px;background:#000;border-radius:50%}
.quiz-option .qcheck{width:20px;height:20px;border-radius:4px;border:2px solid var(--border-light);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all var(--transition)}
.quiz-option.selected .qcheck{border-color:var(--accent);background:var(--accent)}
.quiz-option.selected .qcheck::after{content:'\2713';font-size:12px;color:#000;font-weight:700}
.quiz-nav{display:flex;gap:12px;margin-top:28px}
.quiz-nav .btn-back{padding:14px 28px;background:var(--surface);border:1px solid var(--border);border-radius:100px;color:var(--text-secondary);font-weight:600;font-size:14px;cursor:pointer;transition:all var(--transition)}
.quiz-nav .btn-back:hover{border-color:var(--accent);color:var(--accent)}
.quiz-nav .btn-next{flex:1;padding:14px;background:var(--accent);color:#000;font-weight:700;font-size:15px;border:none;border-radius:100px;cursor:pointer;transition:all var(--transition)}
.quiz-nav .btn-next:hover{box-shadow:0 0 30px var(--accent-glow)}

/* GLOW & HOVER EFFECTS */
.service-card:hover,.project-card:hover,.benefit-card:hover,.magnet-card:hover,.synergy-card:hover{box-shadow:0 20px 60px rgba(0,0,0,.4),0 0 30px rgba(0,230,118,.1)}
.result-card:hover{box-shadow:0 16px 40px rgba(0,0,0,.3),0 0 25px rgba(0,230,118,.15);transform:translateY(-4px) scale(1.03)}
.pricing-card:hover{box-shadow:0 20px 50px rgba(0,0,0,.3),0 0 30px rgba(0,230,118,.12)}
.pricing-card--popular{box-shadow:0 20px 50px rgba(0,0,0,.3),0 0 40px rgba(0,230,118,.15)}
.pricing-card--popular:hover{box-shadow:0 24px 60px rgba(0,0,0,.4),0 0 60px rgba(0,230,118,.25);transform:scale(1.06)}
.stack-item:hover{box-shadow:0 8px 20px rgba(0,0,0,.2),0 0 15px rgba(0,230,118,.12);transform:translateY(-2px) scale(1.05)}
.hero-stat{transition:transform var(--transition)}.hero-stat:hover{transform:scale(1.08)}
.compare-section:hover{box-shadow:0 16px 50px rgba(0,0,0,.3),0 0 25px rgba(0,230,118,.06)}
.calc-card:hover{box-shadow:0 16px 50px rgba(0,0,0,.3),0 0 25px rgba(0,230,118,.06)}
.compare-section,.calc-card{transition:box-shadow var(--transition)}

.hero-stat-num,.result-num,.synergy-pct{text-shadow:0 0 30px rgba(0,230,118,.3)}
.calc-result-val.new,.calc-result-val.diff{text-shadow:0 0 20px rgba(0,230,118,.3)}

.section-title{transition:transform var(--transition);display:inline-block}.section-title:hover{transform:scale(1.02)}

.btn-primary:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 0 60px var(--accent-glow),0 12px 40px rgba(0,230,118,.2)}
.btn-ghost:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 0 20px rgba(0,230,118,.08)}
.navbar-cta:hover{box-shadow:0 0 30px var(--accent-glow),0 8px 20px rgba(0,230,118,.15);transform:translateY(-2px) scale(1.03)}
.pricing-btn:hover{transform:translateY(-2px) scale(1.02)}.magnet-btn:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 0 20px rgba(0,230,118,.15)}
.form-submit:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 0 40px var(--accent-glow),0 12px 30px rgba(0,230,118,.2)}
.quiz-nav .btn-next:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 0 40px var(--accent-glow)}

.flow-num{transition:transform var(--transition),box-shadow var(--transition)}
.flow-step:hover .flow-num{transform:scale(1.12);box-shadow:0 0 25px rgba(0,230,118,.2)}
.flow-step:hover .flow-content h3{color:var(--accent)}
.flow-content h3{transition:color var(--transition)}

.about-fact{transition:all var(--transition)}.about-fact:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px);box-shadow:0 0 15px rgba(0,230,118,.1)}

.quiz-option:hover{box-shadow:0 0 15px rgba(0,230,118,.08)}.quiz-option.selected{box-shadow:0 0 20px rgba(0,230,118,.12)}

.compare-table tbody tr{transition:background var(--transition)}.compare-table tbody tr:hover{background:rgba(0,230,118,.03)}

.result-card::after,.benefit-card::after,.synergy-card::after,.magnet-card::after{content:'';position:absolute;bottom:0;left:10%;right:10%;height:1px;background:var(--accent);box-shadow:0 0 15px 5px rgba(0,230,118,.15);opacity:0;transition:opacity var(--transition);pointer-events:none;border-radius:50%}
.result-card:hover::after,.benefit-card:hover::after,.synergy-card:hover::after,.magnet-card:hover::after{opacity:1}
.synergy-card.synergy-best::after{opacity:.5}
.result-card,.benefit-card,.synergy-card,.magnet-card{position:relative;overflow:hidden}

.floating-phone{display:none;position:fixed;bottom:24px;left:24px;width:56px;height:56px;border-radius:50%;background:var(--blue);align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(56,189,248,.3);z-index:99;color:#fff;font-size:24px;transition:all .3s ease;text-decoration:none}
.floating-phone:hover{transform:scale(1.1);box-shadow:0 6px 30px rgba(56,189,248,.4)}
@media(max-width:768px){.floating-phone{display:flex}}

.footer-links{display:flex;gap:16px;justify-content:center;margin-top:16px;flex-wrap:wrap}
.footer-link{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-size:13px;color:var(--text-muted);transition:all var(--transition)}
.footer-link:hover{border-color:var(--accent);color:var(--accent);box-shadow:0 0 15px rgba(0,230,118,.1);transform:translateY(-1px)}

/* INTEGRATIONS */
.niche-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.niche-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:24px 20px;transition:all var(--transition)}
.niche-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 12px 32px rgba(0,0,0,.25)}
.niche-icon{font-size:28px;display:block;margin-bottom:10px}
.niche-card h3{font-size:15px;font-weight:700;margin-bottom:8px}
.niche-card p{font-size:13px;color:var(--text-secondary);line-height:1.6}

.integr-flow{display:flex;flex-direction:column;gap:28px}
.integr-group{display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap}
.integr-group-label{font-family:var(--mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);font-weight:600;min-width:140px;padding-top:8px;flex-shrink:0}
.integr-items{display:flex;flex-wrap:wrap;gap:8px;flex:1}
.integr-item{padding:7px 16px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-size:13px;color:var(--text-secondary);transition:all var(--transition);font-weight:500}
.integr-item:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-1px)}
.integr-cta{text-align:center;margin-top:40px;font-size:15px;color:var(--text-muted)}.integr-cta strong{color:var(--accent)}

/* DEMO CHAT */
.demo-toggle{position:fixed;bottom:96px;right:24px;width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--purple),#7c3aed);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(167,139,250,.3);z-index:98;cursor:pointer;border:none;color:#fff;font-size:22px;transition:all .3s ease;opacity:0;transform:scale(.8) translateY(20px);pointer-events:none}
.demo-toggle.visible{opacity:1;transform:scale(1) translateY(0);pointer-events:auto}
.demo-toggle:hover{transform:scale(1.1);box-shadow:0 6px 30px rgba(167,139,250,.4)}
.demo-badge{position:absolute;top:-4px;right:-4px;padding:2px 8px;background:var(--accent);border-radius:100px;font-size:10px;font-weight:700;color:#000;font-family:var(--mono)}
.demo-tooltip{position:absolute;right:68px;top:50%;transform:translateY(-50%);white-space:nowrap;padding:8px 16px;background:var(--card);border:1px solid var(--border);border-radius:10px;font-size:13px;font-weight:600;color:var(--text);box-shadow:0 8px 24px rgba(0,0,0,.4);pointer-events:none;animation:tooltipPulse 2s ease-in-out infinite}
.demo-tooltip::after{content:'';position:absolute;right:-6px;top:50%;transform:translateY(-50%);border:6px solid transparent;border-left-color:var(--card)}
@keyframes tooltipPulse{0%,100%{opacity:1}50%{opacity:.6}}
.demo-window{position:fixed;bottom:160px;right:24px;width:380px;max-height:500px;background:var(--bg);border:1px solid var(--border-light);border-radius:20px;z-index:200;display:none;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5),0 0 30px rgba(167,139,250,.1);animation:fadeInUp .3s ease}
.demo-window.open{display:flex}
.demo-header{padding:16px 20px;background:var(--card);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.demo-header-left{display:flex;align-items:center;gap:10px}
.demo-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#000}
.demo-header-info h4{font-size:14px;font-weight:600;margin:0}.demo-header-info span{font-size:11px;color:var(--accent)}
.demo-close{background:none;border:none;color:var(--text-muted);font-size:20px;cursor:pointer;padding:4px;line-height:1;transition:color .2s}
.demo-close:hover{color:var(--text)}
.demo-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;min-height:300px;max-height:340px}
.demo-msg{max-width:85%;padding:10px 14px;border-radius:14px;font-size:13px;line-height:1.5;animation:fadeInUp .3s ease}
.demo-msg.bot{background:var(--card);border:1px solid var(--border);align-self:flex-start;border-bottom-left-radius:4px;color:var(--text-secondary)}
.demo-msg.user{background:var(--accent);color:#000;font-weight:500;align-self:flex-end;border-bottom-right-radius:4px}
.demo-typing{align-self:flex-start;padding:12px 16px;background:var(--card);border:1px solid var(--border);border-radius:14px;border-bottom-left-radius:4px;display:none;gap:4px}
.demo-typing.show{display:flex}
.demo-typing span{width:6px;height:6px;background:var(--text-muted);border-radius:50%;animation:typingDot 1.4s infinite}
.demo-typing span:nth-child(2){animation-delay:.2s}
.demo-typing span:nth-child(3){animation-delay:.4s}
@keyframes typingDot{0%,60%,100%{opacity:.3;transform:translateY(0)}30%{opacity:1;transform:translateY(-4px)}}
.demo-input-wrap{padding:12px 16px;border-top:1px solid var(--border);display:flex;gap:8px}
.demo-input{flex:1;padding:10px 16px;background:var(--surface);border:1px solid var(--border);border-radius:100px;color:var(--text);font-family:var(--sans);font-size:13px;outline:none}
.demo-input:focus{border-color:var(--accent)}
.demo-send{padding:10px 20px;background:var(--accent);color:#000;border:none;border-radius:100px;font-weight:600;font-size:13px;cursor:pointer;transition:all .2s}
.demo-send:hover{box-shadow:0 0 20px var(--accent-glow)}
.demo-quick-btns{display:flex;flex-wrap:wrap;gap:6px;padding:0 16px 12px}
.demo-quick{padding:6px 14px;background:var(--surface);border:1px solid var(--border);border-radius:100px;font-size:11px;color:var(--text-secondary);cursor:pointer;transition:all .2s;font-family:var(--sans)}
.demo-quick:hover{border-color:var(--accent);color:var(--accent)}

/* ANIMATIONS */
@keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-6px)}40%,80%{transform:translateX(6px)}}
@keyframes fadeInDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes kaspiScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.kaspi-scroll{display:flex;gap:16px;animation:kaspiScroll 30s linear infinite;width:max-content}
.kaspi-scroll:hover{animation-play-state:paused}
.kaspi-notif{display:flex;align-items:center;gap:10px;padding:10px 16px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:14px;flex-shrink:0;min-width:200px}
.kaspi-icon{width:32px;height:32px;border-radius:50%;background:rgba(0,230,118,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.kaspi-title{font-size:11px;font-weight:600;color:var(--text);white-space:nowrap}
.kaspi-amount{font-size:12px;color:var(--text-muted);font-family:var(--mono);white-space:nowrap}
.kaspi-time{font-size:10px;color:var(--text-muted);font-family:var(--mono);margin-left:6px;opacity:.6}
/* ROI SCROLL BANNER */
@keyframes roiScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.roi-scroll-wrap{overflow:hidden;mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);-webkit-mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);margin:16px 0 0}
.roi-scroll{display:flex;gap:32px;animation:roiScroll 20s linear infinite;width:max-content}
.roi-scroll:hover{animation-play-state:paused}
.roi-item{display:flex;align-items:center;gap:8px;white-space:nowrap;font-family:var(--mono);font-size:13px;color:var(--text-muted);flex-shrink:0}
.roi-item b{color:var(--accent);font-weight:700}
.roi-sep{color:var(--border-light);font-size:10px}
/* COST COMPARE */
.cost-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:24px;align-items:center;margin-top:32px}
.cost-card{padding:28px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);text-align:center}
.cost-card.bad{border-color:rgba(239,68,68,.2)}
.cost-card.good{border-color:rgba(0,230,118,.2);background:linear-gradient(135deg,var(--card),rgba(0,230,118,.03))}
.cost-line{display:flex;justify-content:space-between;align-items:center;padding:8px 0;font-size:13px;border-bottom:1px solid var(--border)}
.cost-line:last-child{border:0}
.cost-total{margin-top:12px;padding-top:12px;border-top:2px solid var(--border);font-size:18px;font-weight:800;font-family:var(--mono)}
.cost-vs{font-size:24px;font-weight:800;color:var(--text-muted)}
@media(max-width:768px){.cost-grid{grid-template-columns:1fr;gap:16px}.cost-vs{text-align:center}}
/* TRUST PROGRESS BAR */
.trust-progress{position:fixed;bottom:0;left:0;right:calc(80px + 24px);z-index:90;padding:6px 16px;background:rgba(10,10,10,.95);backdrop-filter:blur(12px);border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;transform:translateY(100%);transition:transform .4s ease;font-size:11px}
.trust-progress.visible{transform:translateY(0)}
.trust-progress-bar{flex:1;height:2px;background:var(--border);border-radius:1px;overflow:hidden}
.trust-progress-fill{height:100%;background:var(--accent);border-radius:1px;transition:width .3s ease;width:0}
.trust-progress-text{color:var(--text-muted);font-family:var(--mono);white-space:nowrap;font-size:10px}
.trust-progress-cta{padding:4px 12px;background:var(--accent);color:#000;border-radius:100px;font-size:10px;font-weight:700;text-decoration:none;white-space:nowrap}
@media(max-width:768px){.trust-progress{padding:5px 10px;gap:8px;right:calc(70px + 16px)}.trust-progress-text{font-size:9px;max-width:120px}.trust-progress-cta{display:none}}
/* CONSULTATION CHECKLIST */
.consult-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:20px}
.consult-item{display:flex;align-items:flex-start;gap:10px;padding:14px 18px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm)}
.consult-item svg{flex-shrink:0;margin-top:2px}
@media(max-width:768px){.consult-list{grid-template-columns:1fr}}
/* KZ MAP */
.kz-map-wrap{position:relative;max-width:100%;margin:0}
.kz-map-wrap img{display:block;width:100%;height:auto}
.map-city{position:absolute;transform:translate(-50%,-50%);cursor:pointer;z-index:2}
.map-city::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:8px;height:8px;background:#00e676;border-radius:50%}
.map-city-pulse{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:8px;height:8px;border-radius:50%;border:1.5px solid #00e676;opacity:.5;animation:mapPulse 2s infinite}
@keyframes mapPulse{0%{width:8px;height:8px;opacity:.5}50%{width:22px;height:22px;opacity:0}100%{width:8px;height:8px;opacity:.5}}
.map-city-label{position:absolute;bottom:calc(100% + 4px);left:50%;transform:translateX(-50%);font-size:9px;font-weight:600;color:var(--text);white-space:nowrap;font-family:var(--sans);text-shadow:0 1px 3px rgba(0,0,0,.8)}
.map-city:hover .map-city-label{color:var(--accent)}
.map-tooltip{position:absolute;padding:8px 12px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:11px;pointer-events:none;opacity:0;transition:opacity .3s;white-space:nowrap;z-index:5;box-shadow:0 8px 24px rgba(0,0,0,.4)}
.map-tooltip.show{opacity:1}
.about-bottom{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;align-items:center}
.about-bottom-label{font-size:13px;color:var(--text-muted);margin-bottom:8px;font-family:var(--mono)}
@media(max-width:768px){.about-bottom{grid-template-columns:1fr}.map-city-label{font-size:7px}}
/* INLINE DEMO */
.inline-demo{max-width:600px;margin:32px auto 0;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.inline-demo-header{padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.inline-demo-body{padding:20px;min-height:200px;max-height:300px;overflow-y:auto;display:flex;flex-direction:column;gap:8px}
.inline-demo-input{display:flex;gap:10px;padding:12px 20px;border-top:1px solid var(--border)}
.inline-demo-input input{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 14px;color:var(--text);font-size:14px;outline:0}
.inline-demo-input button{padding:10px 20px;background:var(--accent);color:#000;border:0;border-radius:var(--radius-sm);font-weight:700;cursor:pointer;font-size:14px}
/* RESPONSE TIMER */
.timer-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:32px}
.timer-card{padding:28px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);text-align:center}
.timer-card.bot-timer{border-color:rgba(0,230,118,.2)}
.timer-card.human-timer{border-color:rgba(239,68,68,.2)}
.timer-display{font-size:48px;font-weight:800;font-family:var(--mono);letter-spacing:-2px;margin:12px 0}
.timer-card.bot-timer .timer-display{color:var(--accent)}
.timer-card.human-timer .timer-display{color:#ef4444}
@media(max-width:768px){.timer-grid{grid-template-columns:1fr}}
.reveal{opacity:0;transform:translateY(40px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-children>*{opacity:0;transform:translateY(20px);transition:opacity .5s ease,transform .5s ease}
.reveal-children.visible>*{opacity:1;transform:translateY(0)}
.reveal-children.visible>*:nth-child(1){transition-delay:.05s}
.reveal-children.visible>*:nth-child(2){transition-delay:.1s}
.reveal-children.visible>*:nth-child(3){transition-delay:.15s}
.reveal-children.visible>*:nth-child(4){transition-delay:.2s}
.reveal-children.visible>*:nth-child(5){transition-delay:.25s}
.reveal-children.visible>*:nth-child(6){transition-delay:.3s}
.reveal-children.visible>*:nth-child(7){transition-delay:.35s}
.reveal-children.visible>*:nth-child(8){transition-delay:.4s}
.reveal-children.visible>*:nth-child(9){transition-delay:.45s}
.reveal-children.visible>*:nth-child(10){transition-delay:.5s}
.reveal-children.visible>*:nth-child(11){transition-delay:.55s}
.reveal-children.visible>*:nth-child(12){transition-delay:.6s}

/* RESPONSIVE */
@media(max-width:900px){
.services-grid,.video-grid,.pricing-grid,.magnets-grid,.benefits-grid,.synergy-grid{grid-template-columns:1fr}
.niche-grid{grid-template-columns:repeat(2,1fr)}
.integr-group{flex-direction:column}.integr-group-label{min-width:auto}
.calc-grid{grid-template-columns:1fr}
.projects-grid{grid-template-columns:1fr}
.project-card--featured{grid-template-columns:1fr}
.results-grid{grid-template-columns:repeat(2,1fr)}
.about-grid{grid-template-columns:1fr;text-align:center}
.about-avatar{margin:0 auto}
.about-facts{justify-content:center}
.review-page{grid-template-columns:1fr;grid-template-rows:repeat(4,220px)}
.pricing-card--popular{transform:none}
.pricing-card--popular:hover{transform:translateY(-3px) scale(1)}
.hero-stats{gap:32px}
.compare-table{font-size:13px}
.compare-table th,.compare-table td{padding:10px 8px}
}
@media(max-width:768px){
.container{padding:0 20px}
.section{padding:80px 0}
.navbar{padding:12px 16px}
.navbar-links{display:none}
.mobile-toggle{display:block}
.navbar-cta{padding:8px 16px;font-size:12px}
.navbar.nav-open .navbar-links{display:flex;flex-direction:column;position:absolute;top:100%;left:0;right:0;background:rgba(10,10,10,.95);backdrop-filter:blur(20px);padding:24px 32px;border-bottom:1px solid var(--border);gap:20px}
.hero{min-height:auto;padding:120px 20px 60px}
.hero h1{letter-spacing:-1px}
.hero-rotate-text{font-size:20px}
.hero-rotate{min-width:160px}
.hero-cta-row{flex-direction:column;width:100%}
.hero-cta-row .btn-primary,.hero-cta-row .btn-book,.hero-cta-row .btn-ghost{width:100%;justify-content:center}
.hero-split{grid-template-columns:1fr;gap:24px;justify-items:center}
.hero-bot{max-width:100%}
.hero-pain{max-width:100%}
.pain-counter-num{font-size:32px}
.pain-counter-label{font-size:12px}
.hero-cta-group{flex-direction:column;width:100%}
.btn-primary,.btn-ghost{width:100%;justify-content:center}
.hero-stats{flex-direction:column;gap:20px}
.results-grid{grid-template-columns:1fr 1fr}
.flow-steps::before{left:24px}
.flow-num{width:48px;height:48px;min-width:48px;font-size:18px}
.flow-step{gap:20px}
.cta-box{padding:40px 24px}
.calc-card{padding:28px 20px}
.demo-window{width:calc(100vw - 32px);right:16px;bottom:188px}
.demo-toggle{bottom:136px;right:16px;width:44px;height:44px;font-size:18px}
.cta-buttons{flex-direction:column}
.contact-form{grid-template-columns:1fr}
.compare-section{padding:28px 20px}
.compare-table{display:block;overflow-x:auto}
}
@media(max-width:480px){
.results-grid{grid-template-columns:1fr}
.hero-stat-num{font-size:28px}
}

/* BEFORE/AFTER DIALOGS */
.ba-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:40px}
.ba-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:all .3s ease}
.ba-card:hover{transform:translateY(-3px);box-shadow:0 16px 40px rgba(0,0,0,.3)}
.ba-header{padding:12px 16px;border-bottom:1px solid var(--border);font-family:var(--mono);font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase}
.ba-card.bad .ba-header{color:#ff5252;background:rgba(255,82,82,.06)}
.ba-card.good .ba-header{color:var(--accent);background:var(--accent-dim)}
.ba-chat{padding:16px;display:flex;flex-direction:column;gap:8px;min-height:160px}
.ba-msg{max-width:82%;padding:8px 12px;border-radius:12px;font-size:12px;line-height:1.5}
.ba-msg-client{background:var(--accent);color:#000;font-weight:500;align-self:flex-end;border-bottom-right-radius:4px}
.ba-msg-bot{background:var(--surface);border:1px solid var(--border);align-self:flex-start;border-bottom-left-radius:4px;color:var(--text-secondary)}
.ba-time{font-size:10px;color:var(--text-muted);text-align:right}
.ba-silence{text-align:center;padding:20px 0;color:var(--text-muted);font-size:12px;font-style:italic}
.ba-verdict{padding:10px 16px;font-size:12px;font-weight:600;border-top:1px solid var(--border)}
.ba-card.bad .ba-verdict{color:#ff5252;background:rgba(255,82,82,.04)}
.ba-card.good .ba-verdict{color:var(--accent);background:var(--accent-dim)}
@media(max-width:768px){.ba-grid{grid-template-columns:1fr}}
@media(max-width:768px){.objections-grid{grid-template-columns:1fr !important}.security-bar{flex-direction:column;text-align:center;gap:20px !important}.security-bar>div:first-child{margin:0 auto}}

/* AGGREGATE STATS */
.agg-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:40px}
.agg-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:28px 20px;text-align:center;transition:all .3s ease}
.agg-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 16px 40px rgba(0,0,0,.3),0 0 20px rgba(0,230,118,.08)}
.agg-num{font-family:var(--mono);font-size:clamp(28px,4vw,40px);font-weight:800;color:var(--accent);line-height:1;margin-bottom:8px}
.agg-label{font-size:14px;color:var(--text-secondary);line-height:1.4}
.agg-source{font-size:11px;color:var(--text-muted);margin-top:6px;font-family:var(--mono)}
@media(max-width:768px){.agg-grid{grid-template-columns:repeat(2,1fr)}}

/* MICRO CTA */
.section-cta{text-align:center;margin-top:48px}
.section-cta .btn-ghost{font-size:14px;padding:14px 28px}

/* REVIEW QUOTES */
.rc-quote{font-size:12px;color:var(--text-muted);margin-top:6px;line-height:1.4;font-style:italic;max-width:220px}

/* EXIT POPUP */
.exit-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:9999;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s ease}
.exit-overlay.show{opacity:1;pointer-events:auto}
.exit-popup{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:48px 40px;max-width:480px;width:90%;text-align:center;transform:scale(.9) translateY(20px);transition:transform .3s ease;position:relative}
.exit-overlay.show .exit-popup{transform:scale(1) translateY(0)}
.exit-close{position:absolute;top:16px;right:16px;background:none;border:none;color:var(--text-muted);font-size:24px;cursor:pointer;transition:color .3s;line-height:1;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:50%}
.exit-close:hover{color:var(--text);background:rgba(255,255,255,.05)}
/* Back to top */
.btt{position:fixed;bottom:164px;right:28px;z-index:999;width:44px;height:44px;background:var(--card);border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;pointer-events:none;transition:all .3s ease}
.btt.visible{opacity:1;pointer-events:auto}
.btt:hover{border-color:var(--accent);background:var(--accent-dim);transform:translateY(-2px)}
.btt svg{width:18px;height:18px;stroke:var(--text-muted);stroke-width:2;fill:none}
.btt:hover svg{stroke:var(--accent)}
/* Smooth page entry */
body{animation:pageIn .6s ease both}
@keyframes pageIn{from{opacity:0}to{opacity:1}}
/* WA pulse + tooltip */
@keyframes waPulse{0%{box-shadow:0 0 0 0 rgba(37,211,102,.5)}70%{box-shadow:0 0 0 18px rgba(37,211,102,0)}100%{box-shadow:0 0 0 0 rgba(37,211,102,0)}}
.wa-tooltip{position:fixed;bottom:42px;right:92px;z-index:999;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:8px 14px;font-size:13px;font-weight:500;color:var(--text);white-space:nowrap;opacity:0;transform:translateX(10px);transition:all .3s ease;pointer-events:none;box-shadow:0 4px 20px rgba(0,0,0,.3)}
.wa-tooltip::after{content:'';position:absolute;right:-6px;top:50%;transform:translateY(-50%);border:6px solid transparent;border-left-color:var(--card)}
.wa-tooltip.show{opacity:1;transform:translateX(0)}
/* Mobile sticky CTA */
.mobile-cta{display:none;position:fixed;bottom:0;left:0;right:0;z-index:998;padding:12px 16px;padding-bottom:max(12px,env(safe-area-inset-bottom));background:rgba(10,10,10,.95);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-top:1px solid var(--border)}
.mobile-cta a{display:flex;align-items:center;justify-content:center;gap:8px;padding:14px;background:#25d366;color:#fff;font-weight:700;font-size:15px;border-radius:100px;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.3)}
.mobile-cta svg{width:20px;height:20px;fill:#fff}
@media(max-width:768px){
.mobile-cta{display:block}
.floating-wa{bottom:80px;right:16px;width:48px;height:48px}
.floating-wa svg{width:24px;height:24px}
.wa-tooltip{bottom:94px;right:72px}
.btt{bottom:188px;right:16px;width:38px;height:38px}
footer{padding-bottom:72px}
}
.exit-icon{font-size:48px;margin-bottom:20px;display:block}
.exit-popup h3{font-size:24px;font-weight:800;margin-bottom:12px;letter-spacing:-.5px}
.exit-popup p{font-size:15px;color:var(--text-secondary);margin-bottom:28px;line-height:1.6}
.exit-btns{display:flex;flex-direction:column;gap:12px}
.exit-btns .btn-primary{justify-content:center;font-size:15px;padding:16px 28px}
.exit-btns .btn-ghost{justify-content:center;font-size:14px;padding:12px 24px}
/* Accessibility */
.skip-link{position:absolute;top:-100px;left:16px;z-index:9999;padding:12px 24px;background:var(--accent);color:#000;font-weight:700;font-size:14px;border-radius:100px;text-decoration:none;transition:top .2s}
.skip-link:focus{top:16px}
.field-error{display:none;font-size:12px;color:#ff5252;margin-top:4px;font-family:var(--mono)}
.field-error.show{display:block;animation:shake .4s ease}
.form-group input.error{border-color:#ff5252!important}
@keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-6px)}40%,80%{transform:translateX(6px)}}
*:focus-visible{outline:2px solid var(--accent);outline-offset:2px;border-radius:4px}
/* Swipe hint – mobile only */
.swipe-hint{display:none;position:absolute;bottom:80px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.7);backdrop-filter:blur(8px);color:var(--text-secondary);font-family:var(--mono);font-size:13px;letter-spacing:2px;padding:10px 24px;border-radius:100px;border:1px solid var(--border);pointer-events:none;opacity:0;z-index:10;white-space:nowrap}
@media(max-width:768px){
.swipe-hint{display:block;animation:swipeHintAnim 3s ease forwards}
}
@keyframes swipeHintAnim{0%{opacity:0;transform:translateX(-50%) translateY(6px)}12%{opacity:1;transform:translateX(-50%) translateY(0)}80%{opacity:1;transform:translateX(-50%) translateY(0)}100%{opacity:0;transform:translateX(-50%) translateY(-4px);display:none}}
</style>
<noscript><style>.reveal,.hero-rotate-wrap,.hero-cta-group,.hero-cta-row,.hero-stats,.trust-bar,.hero-badge,.hero-split{opacity:1!important;transform:none!important;animation:none!important}.hero-bot{display:none}</style></noscript>
</head>
