<div class="exit-overlay" id="exitPopup">
  <div class="exit-popup">
    <button class="exit-close" onclick="closeExit()">&times;</button>
    <span class="exit-icon">&#127891;</span>
    <h3>Бесплатный чек-лист</h3>
    <p>7 процессов в вашем бизнесе, которые ИИ автоматизирует уже сегодня. Отправим в WhatsApp за 2 минуты.</p>
    <div class="exit-btns">
      <a href="https://wa.me/77052051992?text=%D0%A5%D0%BE%D1%87%D1%83%20%D1%87%D0%B5%D0%BA-%D0%BB%D0%B8%D1%81%D1%82%20%D0%BF%D0%BE%20%D0%B0%D0%B2%D1%82%D0%BE%D0%BC%D0%B0%D1%82%D0%B8%D0%B7%D0%B0%D1%86%D0%B8%D0%B8" target="_blank" rel="noopener" class="btn-primary" onclick="closeExit()">Получить чек-лист &#8594;</a>
      <button class="btn-ghost" onclick="closeExit()">Нет, спасибо</button>
    </div>
  </div>
</div>
<script>
(function(){
let shown=false;
function showExit(){
  if(shown)return;
  if(sessionStorage.getItem('exitShown'))return;
  shown=true;
  sessionStorage.setItem('exitShown','1');
  document.getElementById('exitPopup').classList.add('show');
  if(typeof gEvent==='function')gEvent('exit_popup_shown');
}
window.closeExit=function(){document.getElementById('exitPopup').classList.remove('show')};
document.addEventListener('mouseout',function(e){
  if(!e.relatedTarget&&e.clientY<5)showExit();
});
document.getElementById('exitPopup').addEventListener('click',function(e){
  if(e.target===this)closeExit();
});
let scrollDepth=0;
window.addEventListener('scroll',function(){
  const pct=window.scrollY/(document.body.scrollHeight-window.innerHeight)*100;
  if(pct>scrollDepth)scrollDepth=pct;
});
setTimeout(function(){if(scrollDepth>60&&!shown&&!('ontouchstart' in window))showExit()},45000);
})();
</script>

