    <div class="trust-logos">
      <a href="case-amadey.html" class="trust-logo"><picture><source srcset="logos/AMADEY LOGO.webp" type="image/webp"><img src="logos/AMADEY LOGO.jpg" alt="Amadey" width="28" height="28" loading="lazy" style="border-radius:6px;object-fit:contain"></picture>Amadey Music</a>
