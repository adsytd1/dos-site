      <a href="case-rams.html" class="trust-logo"><picture><source srcset="logos/logo rams city.webp" type="image/webp"><img src="logos/logo rams city.jpeg" alt="RAMS" width="28" height="28" loading="lazy" style="border-radius:6px;object-fit:contain"></picture>RAMS Kazakhstan</a>
      <a href="case-kazgeotech.html" class="trust-logo"><picture><source srcset="logos/kazgeotech logo new.webp" type="image/webp"><img src="logos/kazgeotech logo new.png" alt="KazGeoTech" width="28" height="28" loading="lazy" style="border-radius:6px;object-fit:contain"></picture>KazGeoTech</a>
      <a href="case-fortebank.html" class="trust-logo"><img src="logos/forte bank logo.svg" alt="Forte Bank" width="28" height="28" loading="lazy" style="border-radius:6px;object-fit:contain">Forte Bank</a>
      <a class="trust-logo"><picture><source srcset="logos/ADAL LAWYERS LOGO.webp" type="image/webp"><img src="logos/ADAL LAWYERS LOGO.jpg" alt="ADAL LAWYERS" width="28" height="28" loading="lazy" style="border-radius:6px;object-fit:contain"></picture>ADAL LAWYERS</a>
