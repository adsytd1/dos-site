<!-- CALCULATOR -->
<section id="calculator" class="section">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <div class="section-label">Калькулятор</div>
      <h2 class="section-title">Посчитайте рост прибыли с ИИ</h2>
      <p class="section-desc">ИИ в среднем повышает продажи на 30%. Введите свои цифры — увидите разницу.</p>
    </div>
    <div class="calc-card reveal">
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="calc-field">
            <label for="calcSales">Количество заявок в месяц: <span class="calc-val" id="calcSalesVal">100</span></label>
            <input type="range" id="calcSales" min="10" max="1000" value="100" step="10">
          </div>
          <div class="calc-field">
            <label for="calcCheck">Средний чек (&#8376;): <span class="calc-val" id="calcCheckVal">50 000</span></label>
            <input type="range" id="calcCheck" min="5000" max="500000" value="50000" step="5000">
          </div>
          <div class="calc-field">
            <label for="calcConv">Текущая конверсия из заявки в продажу: <span class="calc-val" id="calcConvVal">30%</span></label>
            <input type="range" id="calcConv" min="5" max="80" value="30" step="5">
          </div>
          <div class="calc-field">
            <label for="calcTime">Среднее время ответа менеджера: <span class="calc-val" id="calcTimeVal">2 ч</span></label>
            <input type="range" id="calcTime" min="0" max="24" value="2" step="1">
          </div>
        </div>
        <div class="calc-results">
          <div class="calc-result-row">
            <span class="calc-result-label">Текущая выручка/мес</span>
            <span class="calc-result-val old" id="calcOld">2 500 000 &#8376;</span>
          </div>
          <div class="calc-result-row">
            <span class="calc-result-label">Выручка с ИИ (+30% продаж)</span>
            <span class="calc-result-val new" id="calcNew">3 250 000 &#8376;</span>
          </div>
          <div class="calc-result-row">
            <span class="calc-result-label">Дополнительная прибыль</span>
            <span class="calc-result-val diff" id="calcDiff">+750 000 &#8376;</span>
          </div>
          <div class="calc-result-row">
            <span class="calc-result-label">Теряется заявок из-за ожидания</span>
            <span class="calc-result-val old" id="calcLost">50 заявок/мес</span>
          </div>
          <div class="calc-result-row">
            <span class="calc-result-label">Спасённых заявок с ИИ (ответ 15 сек)</span>
            <span class="calc-result-val new" id="calcSaved">48 заявок/мес</span>
          </div>
          <div class="calc-result-highlight">
            <div class="big" id="calcYear">+9 000 000 &#8376;/год</div>
            <div class="sub">столько вы теряете каждый год без ИИ-ассистента</div>
          </div>
        </div>
      </div>
      <div class="calc-cta">
        <a href="https://wa.me/77052051992?text=%D0%A5%D0%BE%D1%87%D1%83%20%D1%83%D0%B7%D0%BD%D0%B0%D1%82%D1%8C%20%D0%BA%D0%B0%D0%BA%20%D0%98%D0%98%20%D0%BF%D0%BE%D0%B2%D1%8B%D1%81%D0%B8%D1%82%20%D0%BF%D1%80%D0%B8%D0%B1%D1%8B%D0%BB%D1%8C" class="btn-primary">Хочу такой рост &#8594;</a>
      </div>
    </div>
  </div>
</section>
